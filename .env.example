# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=bprs_babel_profile
DB_USERNAME=root
DB_PASSWORD=

# Application Settings
APP_NAME="BPRS Bangka Belitung"
APP_URL=http://localhost
APP_ENV=development
APP_DEBUG=true

# Security
APP_KEY=your_random_32_character_key_here

# Session
SESSION_LIFETIME=3600

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@bprsbabel.id
MAIL_FROM_NAME="${APP_NAME}"

# Upload Limits
MAX_UPLOAD_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp
ALLOWED_DOCUMENT_TYPES=pdf

# Security Settings
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900
PASSWORD_MIN_LENGTH=8
